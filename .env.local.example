# voidexa .env.local — copy to .env.local and fill real values
# .env.local is gitignored; this example documents required vars only.

# ---------------------------------------------------------------------------
# Vast.ai API — see VOIDEXA_VAST_AI_RENDER_MASTER.md Part 2
# Generate at https://cloud.vast.ai/account/ (API Keys tab)
# ---------------------------------------------------------------------------
VAST_API_KEY=replace_with_vast_ai_api_key

# SSH public key path (added to Vast.ai account and used for instance access).
# Relative paths are resolved against the repo root. The matching private key
# stays on Jix's machine and is never uploaded.
VAST_SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub

# Optional human-readable label for your Vast.ai account (logging only).
VAST_ACCOUNT_LABEL=voidexa-primary

# ---------------------------------------------------------------------------
# Supabase Storage — see VOIDEXA_VAST_AI_RENDER_MASTER.md Part 9
# Service role key is required to write to the voidexa-assets bucket.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://ihuljnekxkyqgroklurp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Optional: override bucket name (defaults to render_config.yaml supabase.bucket)
# SUPABASE_BUCKET=voidexa-assets

# ---------------------------------------------------------------------------
# Overrides for render_config.yaml (all optional)
# ---------------------------------------------------------------------------
# VOIDEXA_RENDER_MAX_BUDGET_USD=15
# VOIDEXA_RENDER_MAX_DURATION_HOURS=4
# VOIDEXA_RENDER_DEFAULT_GPU=H100_SXM

# ---------------------------------------------------------------------------
# Google AI Studio — Imagen 4 card art rendering (AFS-5)
# Generate at https://aistudio.google.com/app/apikey
# Required by scripts/generate_card_art_batch.py (Imagen 4 paid tier).
# ---------------------------------------------------------------------------
GOOGLE_AI_STUDIO_API_KEY=replace_with_google_ai_studio_key
